# evidencialo — environment variables (copy to .env.local for local dev)
# Real secrets live in Vercel project settings, never in git.

# --- Supabase (step 02+) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Maps: MapTiler (step 11) ---
NEXT_PUBLIC_MAPTILER_KEY=

# --- Captcha: Cloudflare Turnstile (step 06) ---
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Rate limit: Upstash Redis (step 06) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Optional tuning (defaults shown). Window must match /^\d+\s?(ms|s|m|h|d)$/;
# a malformed value falls back to the default rather than disabling the limit.
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW=10 m

# --- Cron auth: shared secret for /api/cron/* (step 10) ---
CRON_SECRET=
